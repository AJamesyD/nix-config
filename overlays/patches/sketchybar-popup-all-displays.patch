Render popups on the display where they are anchored, not only on
the focused display. Upstream issues:
- https://github.com/FelixKratz/SketchyBar/issues/316
- https://github.com/FelixKratz/SketchyBar/issues/742

Without this patch, popups only render on the display that currently
has keyboard focus. Four active_adid guards enforce this. The refined
approach replaces them with popup.adid checks so the popup draws on
whichever display it is anchored to.

--- a/src/bar.c
+++ b/src/bar.c
@@ -34,7 +34,8 @@ bool bar_draws_item(struct bar* bar, struct bar_item* bar_item) {
     if (bar_item->position == POSITION_POPUP
         && (!bar_item->parent
             || !bar_item->parent->popup.drawing
-            || (bar->adid != g_bar_manager.active_adid)))
+            || (bar_item->parent->popup.adid > 0
+                && bar->adid != bar_item->parent->popup.adid)))
       return false;

     return true;
@@ -41,7 +42,6 @@ bool bar_draws_item(struct bar* bar, struct bar_item* bar_item) {
 }

 static void bar_calculate_popup_anchor_for_bar_item(struct bar* bar, struct bar_item* bar_item) {
-  if (bar->adid != g_bar_manager.active_adid) return;
   struct window* window = bar_item_get_window(bar_item, bar->adid);

   if (!bar_item->popup.overrides_cell_size) {
@@ -179,7 +179,8 @@ bool bar_draws_item(struct bar* bar, struct bar_item* bar_item) {

     bar_item_append_associated_bar(bar_item, bar->adid);

-    if (bar_item->popup.drawing && bar->adid == g_bar_manager.active_adid)
+    if (bar_item->popup.drawing
+        && (bar_item->popup.adid < 1 || bar->adid == bar_item->popup.adid))
       popup_draw(&bar_item->popup);

     if (g_bar_manager.bar_needs_update) {
