# shellcheck disable=SC2148
export DIRENV_WARN_TIMEOUT=10s

# WORKAROUND: devenv race condition (git-hooks.nix #685) can leave
# .pre-commit-config.yaml as a regular file or a dangling symlink.
# Either state breaks GC protection. Remove it so devenv regenerates
# a proper symlink on the next shell entry.
if [ -e .pre-commit-config.yaml ] && [ ! -L .pre-commit-config.yaml ]; then
	rm .pre-commit-config.yaml
elif [ -L .pre-commit-config.yaml ] && [ ! -e .pre-commit-config.yaml ]; then
	rm .pre-commit-config.yaml
fi

use flake . --impure
